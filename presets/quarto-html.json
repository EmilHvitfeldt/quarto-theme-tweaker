{
  "format": "html",
  "presets": [
    {
      "id": "font-family-sans-serif",
      "label": "Body font",
      "group": "Typography",
      "subgroup": "Fonts",
      "sassVar": "$font-family-sans-serif",
      "widget": "select",
      "options": [
        "system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
        "\"Source Sans Pro\", Helvetica, sans-serif",
        "Open Sans, sans-serif",
        "Roboto, sans-serif",
        "Georgia, serif",
        "Helvetica, Arial, sans-serif"
      ],
      "default": "system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif"
    },
    {
      "id": "font-family-monospace",
      "label": "Monospace font",
      "group": "Typography",
      "subgroup": "Fonts",
      "sassVar": "$font-family-monospace",
      "widget": "select",
      "options": [
        "SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "\"Source Code Pro\", monospace",
        "\"Fira Code\", monospace",
        "monospace"
      ],
      "default": "SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    {
      "id": "font-size-root",
      "label": "Root font size",
      "group": "Typography",
      "subgroup": "Sizing",
      "sassVar": "$font-size-root",
      "widget": "slider",
      "unit": "rem",
      "min": 0.75,
      "max": 1.5,
      "step": 0.05,
      "default": 1
    },
    {
      "id": "line-height-base",
      "label": "Line height",
      "group": "Typography",
      "subgroup": "Sizing",
      "sassVar": "$line-height-base",
      "widget": "slider",
      "min": 1,
      "max": 2.2,
      "step": 0.05,
      "default": 1.5
    },
    {
      "id": "toc-font-size",
      "label": "TOC font size",
      "group": "Typography",
      "subgroup": "Sizing",
      "sassVar": "$toc-font-size",
      "widget": "slider",
      "unit": "rem",
      "min": 0.6,
      "max": 1.2,
      "step": 0.05,
      "default": 0.875
    },
    {
      "id": "h1-font-size",
      "label": "Heading 1",
      "group": "Typography",
      "subgroup": "Headings",
      "sassVar": "$h1-font-size",
      "widget": "slider",
      "unit": "rem",
      "min": 1,
      "max": 4,
      "step": 0.1,
      "default": 2.5
    },
    {
      "id": "h2-font-size",
      "label": "Heading 2",
      "group": "Typography",
      "subgroup": "Headings",
      "sassVar": "$h2-font-size",
      "widget": "slider",
      "unit": "rem",
      "min": 1,
      "max": 3.5,
      "step": 0.1,
      "default": 2
    },
    {
      "id": "h3-font-size",
      "label": "Heading 3",
      "group": "Typography",
      "subgroup": "Headings",
      "sassVar": "$h3-font-size",
      "widget": "slider",
      "unit": "rem",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.75
    },
    {
      "id": "h4-font-size",
      "label": "Heading 4",
      "group": "Typography",
      "subgroup": "Headings",
      "sassVar": "$h4-font-size",
      "widget": "slider",
      "unit": "rem",
      "min": 0.9,
      "max": 2.5,
      "step": 0.1,
      "default": 1.5
    },
    {
      "id": "h5-font-size",
      "label": "Heading 5",
      "group": "Typography",
      "subgroup": "Headings",
      "sassVar": "$h5-font-size",
      "widget": "slider",
      "unit": "rem",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.25
    },
    {
      "id": "body-bg",
      "label": "Background",
      "group": "Colors",
      "subgroup": "Base",
      "sassVar": "$body-bg",
      "widget": "color",
      "default": "#FFFFFF",
      "cssVar": "--bs-body-bg",
      "applyScope": ":root"
    },
    {
      "id": "body-color",
      "label": "Text",
      "group": "Colors",
      "subgroup": "Base",
      "sassVar": "$body-color",
      "widget": "color",
      "default": "#1A1A1A",
      "cssVar": "--bs-body-color",
      "applyScope": ":root"
    },
    {
      "id": "primary",
      "label": "Primary",
      "group": "Colors",
      "subgroup": "Theme",
      "sassVar": "$primary",
      "widget": "color",
      "default": "#0072B2",
      "cssVar": "--bs-primary",
      "applyScope": ":root"
    },
    {
      "id": "link-color",
      "label": "Link",
      "group": "Colors",
      "subgroup": "Theme",
      "sassVar": "$link-color",
      "widget": "color",
      "default": "#0072B2",
      "cssVar": "--bs-link-color",
      "applyScope": ":root"
    },
    {
      "id": "input-bg",
      "label": "Input background",
      "group": "Colors",
      "subgroup": "Theme",
      "sassVar": "$input-bg",
      "widget": "color",
      "default": "#FFFFFF"
    },
    {
      "id": "popover-bg",
      "label": "Popover background",
      "group": "Colors",
      "subgroup": "Theme",
      "sassVar": "$popover-bg",
      "widget": "color",
      "default": "#FFFFFF"
    },
    {
      "id": "code-bg",
      "label": "Inline code background",
      "group": "Code",
      "subgroup": "Inline code",
      "sassVar": "$code-bg",
      "widget": "color",
      "default": "#F5F5F5"
    },
    {
      "id": "code-color",
      "label": "Inline code text",
      "group": "Code",
      "subgroup": "Inline code",
      "sassVar": "$code-color",
      "widget": "color",
      "default": "#E69F00"
    },
    {
      "id": "code-block-bg",
      "label": "Background",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-bg",
      "widget": "color",
      "default": "#F5F5F5"
    },
    {
      "id": "code-block-bg-alpha",
      "label": "Background alpha shift",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-bg-alpha",
      "widget": "slider",
      "min": -1,
      "max": 1,
      "step": 0.05,
      "default": -0.35
    },
    {
      "id": "code-block-bg-padding",
      "label": "Background padding",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-bg-padding",
      "widget": "slider",
      "unit": "rem",
      "min": 0,
      "max": 1.5,
      "step": 0.05,
      "default": 0.4
    },
    {
      "id": "code-block-border-left",
      "label": "Left border",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-border-left",
      "widget": "select",
      "options": ["false", "true"],
      "default": "false"
    },
    {
      "id": "code-block-border-left-style",
      "label": "Left border style",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-border-left-style",
      "widget": "select",
      "options": ["solid", "dashed", "dotted", "double"],
      "default": "solid"
    },
    {
      "id": "code-block-border-left-size",
      "label": "Left border size",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-border-left-size",
      "widget": "slider",
      "unit": "px",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "id": "code-block-padding-left",
      "label": "Left padding",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$code-block-padding-left",
      "widget": "slider",
      "unit": "em",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 0.6
    },
    {
      "id": "btn-code-copy-color",
      "label": "Copy button",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$btn-code-copy-color",
      "widget": "color",
      "default": "#6c757d"
    },
    {
      "id": "btn-code-copy-color-active",
      "label": "Copy button (active)",
      "group": "Code",
      "subgroup": "Code blocks",
      "sassVar": "$btn-code-copy-color-active",
      "widget": "color",
      "default": "#0072B2"
    },
    {
      "id": "code-annotation-higlight-color",
      "label": "Annotation border",
      "group": "Code",
      "subgroup": "Annotations",
      "sassVar": "$code-annotation-higlight-color",
      "widget": "color",
      "default": "#ffc107"
    },
    {
      "id": "code-annotation-higlight-bg",
      "label": "Annotation background",
      "group": "Code",
      "subgroup": "Annotations",
      "sassVar": "$code-annotation-higlight-bg",
      "widget": "color",
      "default": "#fff3cd"
    },
    {
      "id": "toc-color",
      "label": "Text",
      "group": "Table of contents",
      "sassVar": "$toc-color",
      "widget": "color",
      "default": "#6c757d"
    },
    {
      "id": "toc-active-border",
      "label": "Active border",
      "group": "Table of contents",
      "sassVar": "$toc-active-border",
      "widget": "color",
      "default": "#0072B2"
    },
    {
      "id": "toc-inactive-border",
      "label": "Inactive border",
      "group": "Table of contents",
      "sassVar": "$toc-inactive-border",
      "widget": "color",
      "default": "#dee2e6"
    },
    {
      "id": "navbar-bg",
      "label": "Navbar background",
      "group": "Navigation",
      "subgroup": "Navbar",
      "sassVar": "$navbar-bg",
      "widget": "color",
      "default": "#0072B2"
    },
    {
      "id": "navbar-fg",
      "label": "Navbar text",
      "group": "Navigation",
      "subgroup": "Navbar",
      "sassVar": "$navbar-fg",
      "widget": "color",
      "default": "#FFFFFF"
    },
    {
      "id": "navbar-hl",
      "label": "Navbar highlight",
      "group": "Navigation",
      "subgroup": "Navbar",
      "sassVar": "$navbar-hl",
      "widget": "color",
      "default": "#FFFFFF"
    },
    {
      "id": "sidebar-bg",
      "label": "Sidebar background",
      "group": "Navigation",
      "subgroup": "Sidebar",
      "sassVar": "$sidebar-bg",
      "widget": "color",
      "default": "#FFFFFF"
    },
    {
      "id": "sidebar-fg",
      "label": "Sidebar text",
      "group": "Navigation",
      "subgroup": "Sidebar",
      "sassVar": "$sidebar-fg",
      "widget": "color",
      "default": "#1A1A1A"
    },
    {
      "id": "sidebar-hl",
      "label": "Sidebar highlight",
      "group": "Navigation",
      "subgroup": "Sidebar",
      "sassVar": "$sidebar-hl",
      "widget": "color",
      "default": "#0072B2"
    },
    {
      "id": "footer-bg",
      "label": "Footer background",
      "group": "Navigation",
      "subgroup": "Footer",
      "sassVar": "$footer-bg",
      "widget": "color",
      "default": "#FFFFFF"
    },
    {
      "id": "footer-fg",
      "label": "Footer text",
      "group": "Navigation",
      "subgroup": "Footer",
      "sassVar": "$footer-fg",
      "widget": "color",
      "default": "#1A1A1A"
    },
    {
      "id": "border-radius",
      "label": "Border radius",
      "group": "Layout",
      "sassVar": "$border-radius",
      "widget": "slider",
      "unit": "rem",
      "min": 0,
      "max": 1.5,
      "step": 0.05,
      "default": 0.25,
      "cssVar": "--bs-border-radius",
      "applyScope": ":root"
    },
    {
      "id": "content-padding-top",
      "label": "Content padding top",
      "group": "Layout",
      "sassVar": "$content-padding-top",
      "widget": "slider",
      "unit": "rem",
      "min": 0,
      "max": 4,
      "step": 0.25,
      "default": 0
    },
    {
      "id": "callout-border-width",
      "label": "Border width",
      "group": "Callouts",
      "subgroup": "Layout",
      "sassVar": "$callout-border-width",
      "widget": "slider",
      "unit": "px",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 5
    },
    {
      "id": "callout-border-scale",
      "label": "Border color shift",
      "group": "Callouts",
      "subgroup": "Layout",
      "sassVar": "$callout-border-scale",
      "widget": "slider",
      "unit": "%",
      "min": -100,
      "max": 100,
      "step": 5,
      "default": 0
    },
    {
      "id": "callout-icon-scale",
      "label": "Icon color shift",
      "group": "Callouts",
      "subgroup": "Layout",
      "sassVar": "$callout-icon-scale",
      "widget": "slider",
      "unit": "%",
      "min": -100,
      "max": 100,
      "step": 5,
      "default": 10
    },
    {
      "id": "callout-margin-top",
      "label": "Margin top",
      "group": "Callouts",
      "subgroup": "Layout",
      "sassVar": "$callout-margin-top",
      "widget": "slider",
      "unit": "rem",
      "min": 0,
      "max": 3,
      "step": 0.25,
      "default": 1.25
    },
    {
      "id": "callout-margin-bottom",
      "label": "Margin bottom",
      "group": "Callouts",
      "subgroup": "Layout",
      "sassVar": "$callout-margin-bottom",
      "widget": "slider",
      "unit": "rem",
      "min": 0,
      "max": 3,
      "step": 0.25,
      "default": 1.25
    },
    {
      "id": "callout-color-note",
      "label": "Note",
      "group": "Callouts",
      "subgroup": "Colors",
      "sassVar": "$callout-color-note",
      "widget": "color",
      "default": "#0d6efd"
    },
    {
      "id": "callout-color-tip",
      "label": "Tip",
      "group": "Callouts",
      "subgroup": "Colors",
      "sassVar": "$callout-color-tip",
      "widget": "color",
      "default": "#198754"
    },
    {
      "id": "callout-color-caution",
      "label": "Caution",
      "group": "Callouts",
      "subgroup": "Colors",
      "sassVar": "$callout-color-caution",
      "widget": "color",
      "default": "#fd7e14"
    },
    {
      "id": "callout-color-warning",
      "label": "Warning",
      "group": "Callouts",
      "subgroup": "Colors",
      "sassVar": "$callout-color-warning",
      "widget": "color",
      "default": "#ffc107"
    },
    {
      "id": "callout-color-important",
      "label": "Important",
      "group": "Callouts",
      "subgroup": "Colors",
      "sassVar": "$callout-color-important",
      "widget": "color",
      "default": "#dc3545"
    }
  ]
}
