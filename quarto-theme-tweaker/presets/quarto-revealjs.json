{
  "format": "revealjs",
  "presets": [
    {
      "id": "body-bg",
      "label": "Background color",
      "group": "Colors",
      "sassVar": "$body-bg",
      "widget": "color",
      "default": "#ffffff",
      "cssVar": "--r-background-color",
      "applyScope": ":root"
    },
    {
      "id": "body-color",
      "label": "Body text color",
      "group": "Colors",
      "sassVar": "$body-color",
      "widget": "color",
      "default": "#222222",
      "cssVar": "--r-main-color",
      "applyScope": ":root"
    },
    {
      "id": "link-color",
      "label": "Link color",
      "group": "Colors",
      "sassVar": "$link-color",
      "widget": "color",
      "default": "#2a76dd",
      "cssVar": "--r-link-color",
      "applyScope": ":root"
    },
    {
      "id": "link-color-hover",
      "label": "Link hover color",
      "group": "Colors",
      "sassVar": "$link-color-hover",
      "widget": "color",
      "default": "#6699e6",
      "cssVar": "--r-link-color-hover",
      "applyScope": ":root"
    },
    {
      "id": "selection-bg",
      "label": "Selection background",
      "group": "Colors",
      "sassVar": "$selection-bg",
      "widget": "color",
      "default": "#98bdee",
      "cssVar": "--r-selection-background-color",
      "applyScope": ":root"
    },
    {
      "id": "selection-color",
      "label": "Selection text color",
      "group": "Colors",
      "sassVar": "$selection-color",
      "widget": "color",
      "default": "#ffffff",
      "cssVar": "--r-selection-color",
      "applyScope": ":root"
    },
    {
      "id": "text-muted",
      "label": "Muted text color",
      "group": "Colors",
      "sassVar": "$text-muted",
      "widget": "color",
      "default": "#919191"
    },
    {
      "id": "font-family-sans-serif",
      "label": "Body font family",
      "group": "Fonts",
      "sassVar": "$font-family-sans-serif",
      "widget": "select",
      "options": [
        "\"Source Sans Pro\", Helvetica, sans-serif",
        "Open Sans, sans-serif",
        "Roboto, sans-serif",
        "Georgia, serif",
        "Helvetica, Arial, sans-serif"
      ],
      "default": "\"Source Sans Pro\", Helvetica, sans-serif",
      "cssVar": "--r-main-font",
      "applyScope": ":root"
    },
    {
      "id": "font-family-monospace",
      "label": "Monospace font family",
      "group": "Fonts",
      "sassVar": "$font-family-monospace",
      "widget": "select",
      "options": [
        "monospace",
        "\"Source Code Pro\", monospace",
        "\"Fira Code\", monospace",
        "Menlo, Consolas, monospace"
      ],
      "default": "monospace",
      "cssVar": "--r-code-font",
      "applyScope": ":root"
    },
    {
      "id": "presentation-font-size-root",
      "label": "Root font size",
      "group": "Fonts",
      "sassVar": "$presentation-font-size-root",
      "widget": "slider",
      "unit": "px",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 40,
      "cssVar": "--r-main-font-size",
      "applyScope": ":root"
    },
    {
      "id": "presentation-font-smaller",
      "label": "Smaller-text scale",
      "group": "Fonts",
      "sassVar": "$presentation-font-smaller",
      "widget": "slider",
      "min": 0.4,
      "max": 1,
      "step": 0.05,
      "default": 0.7
    },
    {
      "id": "presentation-line-height",
      "label": "Body line height",
      "group": "Fonts",
      "sassVar": "$presentation-line-height",
      "widget": "slider",
      "min": 1,
      "max": 2.2,
      "step": 0.05,
      "default": 1.3
    },
    {
      "id": "presentation-h1-font-size",
      "label": "Heading 1 size",
      "group": "Headings",
      "sassVar": "$presentation-h1-font-size",
      "widget": "slider",
      "unit": "em",
      "min": 0.8,
      "max": 5,
      "step": 0.1,
      "default": 2.5,
      "cssVar": "--r-heading1-size",
      "applyScope": ":root"
    },
    {
      "id": "presentation-h2-font-size",
      "label": "Heading 2 size",
      "group": "Headings",
      "sassVar": "$presentation-h2-font-size",
      "widget": "slider",
      "unit": "em",
      "min": 0.8,
      "max": 4,
      "step": 0.1,
      "default": 1.6,
      "cssVar": "--r-heading2-size",
      "applyScope": ":root"
    },
    {
      "id": "presentation-h3-font-size",
      "label": "Heading 3 size",
      "group": "Headings",
      "sassVar": "$presentation-h3-font-size",
      "widget": "slider",
      "unit": "em",
      "min": 0.8,
      "max": 3,
      "step": 0.1,
      "default": 1.3,
      "cssVar": "--r-heading3-size",
      "applyScope": ":root"
    },
    {
      "id": "presentation-h4-font-size",
      "label": "Heading 4 size",
      "group": "Headings",
      "sassVar": "$presentation-h4-font-size",
      "widget": "slider",
      "unit": "em",
      "min": 0.6,
      "max": 2.5,
      "step": 0.1,
      "default": 1,
      "cssVar": "--r-heading4-size",
      "applyScope": ":root"
    },
    {
      "id": "presentation-heading-font",
      "label": "Heading font family",
      "group": "Headings",
      "sassVar": "$presentation-heading-font",
      "widget": "select",
      "options": [
        "\"Source Sans Pro\", Helvetica, sans-serif",
        "Open Sans, sans-serif",
        "Roboto, sans-serif",
        "Georgia, serif",
        "Helvetica, Arial, sans-serif"
      ],
      "default": "\"Source Sans Pro\", Helvetica, sans-serif",
      "cssVar": "--r-heading-font",
      "applyScope": ":root"
    },
    {
      "id": "presentation-heading-color",
      "label": "Heading color",
      "group": "Headings",
      "sassVar": "$presentation-heading-color",
      "widget": "color",
      "default": "#222222",
      "cssVar": "--r-heading-color",
      "applyScope": ":root"
    },
    {
      "id": "presentation-heading-line-height",
      "label": "Heading line height",
      "group": "Headings",
      "sassVar": "$presentation-heading-line-height",
      "widget": "slider",
      "min": 0.8,
      "max": 2,
      "step": 0.05,
      "default": 1.2,
      "cssVar": "--r-heading-line-height",
      "applyScope": ":root"
    },
    {
      "id": "presentation-heading-letter-spacing",
      "label": "Heading letter spacing",
      "group": "Headings",
      "sassVar": "$presentation-heading-letter-spacing",
      "widget": "slider",
      "unit": "px",
      "min": -2,
      "max": 8,
      "step": 0.5,
      "default": 0,
      "cssVar": "--r-heading-letter-spacing",
      "applyScope": ":root"
    },
    {
      "id": "presentation-heading-text-transform",
      "label": "Heading text transform",
      "group": "Headings",
      "sassVar": "$presentation-heading-text-transform",
      "widget": "select",
      "options": ["none", "uppercase", "lowercase", "capitalize"],
      "default": "none",
      "cssVar": "--r-heading-text-transform",
      "applyScope": ":root"
    },
    {
      "id": "presentation-heading-font-weight",
      "label": "Heading font weight",
      "group": "Headings",
      "sassVar": "$presentation-heading-font-weight",
      "widget": "select",
      "options": ["300", "400", "500", "600", "700", "800", "900"],
      "default": "600",
      "cssVar": "--r-heading-font-weight",
      "applyScope": ":root"
    },
    {
      "id": "code-block-bg",
      "label": "Code block background",
      "group": "Code",
      "sassVar": "$code-block-bg",
      "widget": "color",
      "default": "#ffffff"
    },
    {
      "id": "code-block-border-color",
      "label": "Code block border",
      "group": "Code",
      "sassVar": "$code-block-border-color",
      "widget": "color",
      "default": "#cccccc"
    },
    {
      "id": "code-block-font-size",
      "label": "Code block font size",
      "group": "Code",
      "sassVar": "$code-block-font-size",
      "widget": "slider",
      "unit": "em",
      "min": 0.3,
      "max": 1,
      "step": 0.05,
      "default": 0.55
    },
    {
      "id": "code-color",
      "label": "Inline code color",
      "group": "Code",
      "sassVar": "$code-color",
      "widget": "color",
      "default": "#4758ab"
    },
    {
      "id": "code-bg",
      "label": "Inline code background",
      "group": "Code",
      "sassVar": "$code-bg",
      "widget": "color",
      "default": "#ffffff"
    },
    {
      "id": "border-color",
      "label": "Border color",
      "group": "Layout",
      "sassVar": "$border-color",
      "widget": "color",
      "default": "#6f6f6f"
    },
    {
      "id": "border-width",
      "label": "Border width",
      "group": "Layout",
      "sassVar": "$border-width",
      "widget": "slider",
      "unit": "px",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "id": "border-radius",
      "label": "Border radius",
      "group": "Layout",
      "sassVar": "$border-radius",
      "widget": "slider",
      "unit": "px",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 3
    },
    {
      "id": "presentation-block-margin",
      "label": "Block margin",
      "group": "Layout",
      "sassVar": "$presentation-block-margin",
      "widget": "slider",
      "unit": "px",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 12,
      "cssVar": "--r-block-margin",
      "applyScope": ":root"
    },
    {
      "id": "presentation-slide-text-align",
      "label": "Slide text align",
      "group": "Layout",
      "sassVar": "$presentation-slide-text-align",
      "widget": "select",
      "options": ["left", "center", "right"],
      "default": "left"
    },
    {
      "id": "presentation-title-slide-text-align",
      "label": "Title slide text align",
      "group": "Layout",
      "sassVar": "$presentation-title-slide-text-align",
      "widget": "select",
      "options": ["left", "center", "right"],
      "default": "center"
    },
    {
      "id": "callout-color-note",
      "label": "Callout: note",
      "group": "Callouts",
      "sassVar": "$callout-color-note",
      "widget": "color",
      "default": "#0d6efd"
    },
    {
      "id": "callout-color-tip",
      "label": "Callout: tip",
      "group": "Callouts",
      "sassVar": "$callout-color-tip",
      "widget": "color",
      "default": "#198754"
    },
    {
      "id": "callout-color-caution",
      "label": "Callout: caution",
      "group": "Callouts",
      "sassVar": "$callout-color-caution",
      "widget": "color",
      "default": "#fd7e14"
    },
    {
      "id": "callout-color-warning",
      "label": "Callout: warning",
      "group": "Callouts",
      "sassVar": "$callout-color-warning",
      "widget": "color",
      "default": "#ffc107"
    },
    {
      "id": "callout-color-important",
      "label": "Callout: important",
      "group": "Callouts",
      "sassVar": "$callout-color-important",
      "widget": "color",
      "default": "#dc3545"
    }
  ]
}
